# ------------------------------------------------------------------------------
# Nexus Control Center — production environment template
#
# Copy this file to `.env` on the deploy host, replace every `CHANGEME` +
# placeholder, then run `php artisan key:generate` once on first install to
# generate APP_KEY.
#
# Diff-from-dev summary:
#   - APP_ENV=production, APP_DEBUG=false, LOG_LEVEL=warning
#   - MySQL/Postgres + Redis with password placeholders (no SQLite)
#   - HORIZON_ALLOW_LIST empty (populate before deploy — see
#     docs/security/operator-checklist.md §3)
#   - SESSION_DOMAIN + SANCTUM_STATEFUL_DOMAINS explicit for multi-host prod
#   - TELESCOPE_ENABLED=false
#   - MAIL_MAILER + MAIL_FROM_ADDRESS templated
#   - Dev-only tunnel knobs (VITE_DEV_SERVER_URL, cloudflared) removed
#
# See docs/installation.md, docs/deployment.md, docs/backup.md.
# ------------------------------------------------------------------------------

APP_NAME="Nexus Control Center"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://nexus.example.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ---- Database ---------------------------------------------------------------
# MySQL 8+ or PostgreSQL 15+. SQLite is dev-only.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexus
DB_USERNAME=nexus
DB_PASSWORD=CHANGEME

# ---- Redis / cache / queue / session ----------------------------------------
# Horizon requires the redis queue driver. Sessions in Redis so multi-worker
# setups share auth state.
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
BROADCAST_CONNECTION=reverb

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGEME

# ---- Cookies / cross-host session -------------------------------------------
# Set SESSION_DOMAIN to the parent domain when Reverb / API run on a subdomain
# (e.g., `.nexus.example.com` covers `app.nexus.example.com` +
# `ws.nexus.example.com`). Leave blank for single-host installs.
SESSION_DOMAIN=
SANCTUM_STATEFUL_DOMAINS=nexus.example.com

# ---- Horizon ----------------------------------------------------------------
# Comma-separated verified-user emails allowed to reach /horizon in production.
# Empty list = zero access (fail closed). See docs/security/operator-checklist.md §3.
HORIZON_ALLOW_LIST=

# ---- Reverb (websockets) ----------------------------------------------------
# The php process talks to Reverb on localhost. Browsers reach it through the
# public VITE_REVERB_HOST (Nginx / Caddy vhost with the WebSocket upgrade).
REVERB_APP_ID=nexus
REVERB_APP_KEY=CHANGEME
REVERB_APP_SECRET=CHANGEME
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=ws.nexus.example.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ---- GitHub App -------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://nexus.example.com/integrations/github/callback
GITHUB_WEBHOOK_SECRET=CHANGEME

# ---- Mail -------------------------------------------------------------------
# Verification + password-reset emails ship through here. Configure at least a
# from-address; use the log driver only for smoke tests.
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="nexus@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Telescope --------------------------------------------------------------
# Keep off in production. Enabled Telescope inflates DB rows fast.
TELESCOPE_ENABLED=false

# ---- Agent telemetry --------------------------------------------------------
# Optional override; the default (120s) is fine for most deploys.
# HOSTS_HEARTBEAT_TIMEOUT_SECONDS=120

# ---- Vite dev server --------------------------------------------------------
# Dev-only. Left blank / unset in production (npm run build handles assets).
# VITE_DEV_SERVER_URL=
